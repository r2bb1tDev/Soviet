{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Soviet",
  "version": "1.3.0",
  "identifier": "app.soviet.messenger",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Soviet",
        "width": 900,
        "height": 620,
        "minWidth": 560,
        "minHeight": 480,
        "resizable": true,
        "decorations": true,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi", "dmg", "app", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "digestAlgorithm": "sha256",
      "certificateThumbprint": null,
      "timestampUrl": ""
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/r2bb1tDev/Soviet/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQzOUZBMkEwOEUzOEVDODAKUldTQTdEaU9vS0tmUXdJdjJDZzBYSDlRZ1c3UFNBSU5mOWNycXNocUpTaFBoNTZqc0lyQkhWRWsK"
    }
  }
}
